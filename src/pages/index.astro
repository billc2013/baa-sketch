---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Content as Intro } from '../content/home/intro.md';
import { Content as WhyBiomimicry } from '../content/home/why-biomimicry.md';

const cards = [
  {
    href: '/classroom-resources/',
    title: 'Classroom Resources',
    blurb: 'Pre-built lessons and the ingredients to build your own biomimicry design challenges.',
  },
  {
    href: '/professional-development/',
    title: 'Professional Development',
    blurb: 'Workshop slides, hour-long PD, design-challenge facilitation, and S/F analysis support.',
  },
  {
    href: '/research-and-team/',
    title: 'Research & Team',
    blurb: 'Publications, the Pedagogical Design Capacity model, and the people behind the project.',
  },
];
---
<BaseLayout title="Home">
  <section class="hero markdown">
    <Intro />
  </section>

  <section class="why markdown">
    <WhyBiomimicry />
  </section>

  <section class="card-grid">
    {cards.map(c => (
      <a class="card" href={c.href}>
        <h3>{c.title}</h3>
        <p>{c.blurb}</p>
      </a>
    ))}
  </section>
</BaseLayout>
